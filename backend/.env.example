# Server
PORT=3001
NODE_ENV=development

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=payment_db

# Alternative: single connection string (overrides the variables above)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/payment_db

# AES-256-GCM encryption key (must be exactly 32 bytes / 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000
